# HOW TO USE:
#   cp env.example .env
#   Edit .env if needed (defaults work for local Docker)

POSTGRES_DB=scalea_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email backend (local dev: console; staging/prod: smtp)
# For local development, you can use the console email backend which will print emails to the console instead of sending them.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For staging/production, configure the SMTP email backend with your email service provider's settings.
#EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=example@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=example@gmail.com

FRONTEND_URL=http://localhost:5173

# Security (required for registration protection)
# reCAPTCHA v2 — use Google test keys for local dev (see https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:5173
